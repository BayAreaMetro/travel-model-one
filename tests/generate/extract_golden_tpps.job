          ",", MW[12](15.6f),
          ",", MW[13](15.6f),
          ",", MW[14](15.6f),
          ",", MW[15](15.6f),
          ",", MW[16](15.6f),
          ",", MW[17](15.6f),
          ",", MW[18](15.6f),
          ",", MW[19](15.6f),
          ",", MW[20](15.6f),
          ",", MW[21](15.6f),
          PRINTO=1
      ENDIF
    ENDJLOOP

ENDRUN

