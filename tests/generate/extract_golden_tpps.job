; =======================================================================

; --- dump HWYSKMEA.tpp → HWYSKMEA.csv ---
RUN PGM=MATRIX
    FILEI MATI[1] = "E:\Model3C-Share\Projects\2023_TM161_IPA_35_testrun\skims\golden_tpp\HWYSKMEA.tpp"
