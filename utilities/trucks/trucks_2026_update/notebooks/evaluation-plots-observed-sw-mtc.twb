      <aliases enabled='yes' />
      <column caption='Observed Volume' datatype='real' name='[Calculation_3157032869621760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [type] = &quot;observed&quot; THEN [volume] END' />
      </column>
      <column caption='Predicted Volume - TM-1.6' datatype='real' name='[Calculation_3157032869978113]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [source] = &apos;MTC&apos; THEN [volume] END' />
      </column>
      <column caption='Calculation1' datatype='boolean' name='[Calculation_3157032870572034]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([Calculation_3157032869621760]) &#13;&#10;AND NOT ISNULL([Calculation_3157032869978113])' />
      </column>
      <column aggregation='Sum' caption='Has observed Volume' datatype='integer' name='[Calculation_3157032871112707]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [link_id], [tod] :&#13;&#10;    MAX(&#13;&#10;        IF [type] = &quot;observed&quot;&#13;&#10;        AND NOT ISNULL([volume])&#13;&#10;        THEN 1&#13;&#10;        ELSE 0&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Pearson Correlation - TM-1.6' datatype='real' name='[Calculation_3157032878956549]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_CORR(SUM([Calculation_3157032869621760]), SUM([Calculation_3157032869978113]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='1:1 Line' datatype='real' name='[Calculation_3157032881623049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_3157032869621760])' />
      </column>
      <column caption='Percent Error - TM-1.6' datatype='real' name='[Calculation_3803546009939968]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_3157032869978113]) - SUM([Calculation_3157032869621760])) / SUM([Calculation_3157032869621760])' />
      </column>
      <column caption='Δ Abs Percent Error ( TM-1.6 - SW)' datatype='real' name='[Calculation_3803546028687365]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Percent Error - MTC (copy)_3803546017275906] - [Percent Error - SW (copy)_3803546021003268]' />
      </column>
      <column caption='Line Size' datatype='real' name='[Calculation_3803546033299463]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_3157032871112707]= 1 THEN&#13;&#10;    10        // emphasize links with observations&#13;&#10;ELSE&#13;&#10;    0.01      // very thin background links&#13;&#10;END' />
      </column>
      <column caption='Observed Source' datatype='string' name='[Has observed Volume (copy)_2437348669116416]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [link_id]:&#13;&#10;    MAX(&#13;&#10;        IF [type] = &quot;observed&quot;&#13;&#10;        THEN [source]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Pearson Correlation -SW' datatype='real' name='[MTC Pearson Correlation (copy)_3157032881000455]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_CORR(SUM([Calculation_3157032869621760]), SUM([MTC Volume (copy)_3157032877101060]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Predicted Volume - SW' datatype='real' name='[MTC Volume (copy)_3157032877101060]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [source] = &apos;SW&apos; THEN [volume] END' />
      </column>
      <column caption='Percent Error - SW' datatype='real' name='[Percent Error - MTC (copy)_3803546010161153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([MTC Volume (copy)_3157032877101060]) - SUM([Calculation_3157032869621760])) / SUM([Calculation_3157032869621760])' />
      </column>
      <column caption='Absolute Percent Error - TM-1.6' datatype='real' name='[Percent Error - MTC (copy)_3803546017275906]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS(SUM([Calculation_3157032869978113]) - SUM([Calculation_3157032869621760])) / SUM([Calculation_3157032869621760])' />
      </column>
      <column caption='Absolute Percent Error - SW' datatype='real' name='[Percent Error - SW (copy)_3803546021003268]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS((SUM([MTC Volume (copy)_3157032877101060]) - SUM([Calculation_3157032869621760]))) / SUM([Calculation_3157032869621760])' />
      </column>
